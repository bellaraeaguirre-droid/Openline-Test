<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>openline. — honest together.</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FAF6F0;
      --warm-red: #C94F3A;
      --blush: #F2A89A;
      --yellow: #F5C842;
      --sky: #A8C8D8;
      --dark: #2A1F1A;
      --mid: #7A5C52;
    }

- { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
background: var(–cream);
font-family: ‘DM Sans’, sans-serif;
color: var(–dark);
overflow-x: hidden;
}

/* NAV */
nav {
display: flex;
justify-content: space-between;
align-items: center;
padding: 28px 48px;
position: fixed;
top: 0; left: 0; right: 0;
z-index: 100;
background: var(–cream);
border-bottom: 1.5px solid rgba(42,31,26,0.08);
}

.nav-logo {
font-family: ‘Playfair Display’, serif;
font-size: 22px;
font-weight: 700;
color: var(–dark);
letter-spacing: -0.5px;
}

.nav-links {
display: flex;
gap: 36px;
list-style: none;
}

.nav-links a {
color: var(–mid);
text-decoration: none;
font-size: 14px;
font-weight: 400;
transition: color 0.2s;
}

.nav-links a:hover { color: var(–dark); }

.nav-cta {
background: var(–warm-red);
color: white;
border: none;
padding: 10px 22px;
border-radius: 100px;
font-size: 14px;
font-weight: 500;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: transform 0.15s, background 0.15s;
}

.nav-cta:hover {
background: #B03D2A;
transform: translateY(-1px);
}

/* HERO */
.hero {
min-height: 100vh;
display: grid;
grid-template-columns: 1fr 1fr;
align-items: center;
padding: 120px 48px 80px;
gap: 60px;
position: relative;
}

.hero::before {
content: ‘’;
position: absolute;
top: 80px; right: 0;
width: 55%;
height: calc(100% - 80px);
background: var(–blush);
border-radius: 40px 0 0 40px;
opacity: 0.18;
z-index: 0;
}

.hero-left {
position: relative;
z-index: 1;
animation: fadeUp 0.8s ease both;
}

.hero-tag {
display: inline-flex;
align-items: center;
gap: 8px;
background: var(–yellow);
color: var(–dark);
font-size: 12px;
font-weight: 500;
padding: 6px 14px;
border-radius: 100px;
margin-bottom: 28px;
letter-spacing: 0.04em;
}

.hero-tag span {
width: 6px; height: 6px;
border-radius: 50%;
background: var(–warm-red);
display: inline-block;
}

h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(52px, 6vw, 76px);
font-weight: 900;
line-height: 1.0;
letter-spacing: -2px;
color: var(–dark);
margin-bottom: 24px;
}

h1 em {
font-style: italic;
color: var(–warm-red);
}

.hero-sub {
font-size: 17px;
color: var(–mid);
line-height: 1.65;
max-width: 420px;
margin-bottom: 40px;
font-weight: 300;
}

.hero-actions {
display: flex;
gap: 14px;
align-items: center;
flex-wrap: wrap;
}

.btn-primary {
background: var(–warm-red);
color: white;
border: none;
padding: 16px 32px;
border-radius: 100px;
font-size: 15px;
font-weight: 500;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: transform 0.15s, background 0.15s;
}

.btn-primary:hover {
background: #B03D2A;
transform: translateY(-2px);
}

.btn-ghost {
background: none;
border: 1.5px solid rgba(42,31,26,0.2);
color: var(–dark);
padding: 15px 28px;
border-radius: 100px;
font-size: 15px;
font-weight: 400;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: border-color 0.15s, transform 0.15s;
}

.btn-ghost:hover {
border-color: var(–dark);
transform: translateY(-2px);
}

/* PHONE MOCKUP */
.hero-right {
position: relative;
z-index: 1;
display: flex;
justify-content: center;
align-items: center;
animation: fadeUp 0.8s ease 0.15s both;
}

.phone-wrap {
position: relative;
width: 260px;
}

.phone-frame {
width: 260px;
background: #FAF6F0;
border-radius: 36px;
overflow: hidden;
border: 1.5px solid rgba(42,31,26,0.12);
box-shadow: 0 40px 80px rgba(42,31,26,0.18), 0 8px 24px rgba(42,31,26,0.10);
padding: 16px 14px 24px;
}

.phone-status {
display: flex;
justify-content: space-between;
font-size: 10px;
color: #2A1F1A;
font-weight: 600;
margin-bottom: 14px;
padding: 0 4px;
}

.phone-header {
margin-bottom: 16px;
padding: 0 4px;
}

.phone-app-name {
font-family: ‘Playfair Display’, serif;
font-size: 18px;
color: #2A1F1A;
font-weight: 700;
margin-bottom: 4px;
}

.phone-consent {
background: rgba(89,170,100,0.1);
border: 1px solid rgba(89,170,100,0.25);
border-radius: 10px;
padding: 8px 10px;
display: flex;
align-items: center;
gap: 7px;
margin-bottom: 14px;
}

.phone-consent-dot {
width: 6px; height: 6px;
border-radius: 50%;
background: #59AA64;
flex-shrink: 0;
}

.phone-consent-text {
color: #59AA64;
font-size: 10px;
font-weight: 600;
}

.phone-card {
background: white;
border: 1px solid rgba(42,31,26,0.08);
border-radius: 14px;
padding: 12px;
margin-bottom: 8px;
}

.phone-card-top {
display: flex;
align-items: center;
gap: 8px;
margin-bottom: 10px;
}

.phone-avatar {
width: 32px; height: 32px;
border-radius: 9px;
display: flex;
align-items: center;
justify-content: center;
font-size: 11px;
font-weight: 700;
flex-shrink: 0;
}

.phone-card-name {
color: #2A1F1A;
font-size: 12px;
font-weight: 600;
flex: 1;
}

.phone-card-status {
font-size: 9px;
font-weight: 600;
padding: 2px 7px;
border-radius: 100px;
}

.phone-activity {
background: #FAF6F0;
border: 1px solid rgba(42,31,26,0.07);
border-radius: 9px;
padding: 8px 10px;
display: flex;
align-items: center;
gap: 8px;
}

.phone-activity-icon {
font-size: 14px;
}

.phone-activity-text {
flex: 1;
}

.phone-activity-name {
color: #2A1F1A;
font-size: 10px;
font-weight: 500;
margin-bottom: 1px;
}

.phone-activity-domain {
color: #7A5C52;
font-size: 9px;
}

.phone-activity-time {
color: #C94F3A;
font-size: 10px;
font-weight: 600;
}

/* Floating badge */
.float-badge {
position: absolute;
background: var(–yellow);
border-radius: 14px;
padding: 10px 14px;
box-shadow: 0 8px 24px rgba(42,31,26,0.15);
}

.float-badge-1 {
top: 30px;
right: -40px;
font-size: 11px;
font-weight: 600;
color: var(–dark);
white-space: nowrap;
}

.float-badge-2 {
bottom: 40px;
left: -50px;
background: var(–sky);
font-size: 11px;
font-weight: 600;
color: var(–dark);
white-space: nowrap;
}

/* HOW IT WORKS */
.section {
padding: 100px 48px;
}

.section-label {
font-size: 11px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–warm-red);
margin-bottom: 16px;
}

.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(36px, 4vw, 52px);
font-weight: 800;
line-height: 1.1;
letter-spacing: -1.5px;
color: var(–dark);
margin-bottom: 60px;
max-width: 560px;
}

.steps {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 24px;
}

.step {
background: white;
border-radius: 24px;
padding: 32px 28px;
border: 1.5px solid rgba(42,31,26,0.06);
transition: transform 0.2s, box-shadow 0.2s;
animation: fadeUp 0.6s ease both;
}

.step:hover {
transform: translateY(-4px);
box-shadow: 0 16px 40px rgba(42,31,26,0.1);
}

.step:nth-child(2) { animation-delay: 0.1s; background: var(–warm-red); }
.step:nth-child(3) { animation-delay: 0.2s; }

.step:nth-child(2) .step-num,
.step:nth-child(2) .step-title,
.step:nth-child(2) .step-desc { color: white; }

.step:nth-child(2) .step-num { opacity: 0.6; }

.step-num {
font-family: ‘Playfair Display’, serif;
font-size: 48px;
font-weight: 900;
color: rgba(42,31,26,0.08);
line-height: 1;
margin-bottom: 20px;
}

.step-icon {
font-size: 28px;
margin-bottom: 16px;
}

.step-title {
font-family: ‘Playfair Display’, serif;
font-size: 22px;
font-weight: 700;
color: var(–dark);
margin-bottom: 10px;
letter-spacing: -0.3px;
}

.step-desc {
font-size: 14px;
color: var(–mid);
line-height: 1.65;
font-weight: 300;
}

/* WHY SECTION */
.why {
background: var(–dark);
padding: 100px 48px;
border-radius: 40px;
margin: 0 24px;
position: relative;
overflow: hidden;
}

.why::before {
content: ‘’;
position: absolute;
top: -100px; right: -100px;
width: 400px; height: 400px;
background: var(–warm-red);
border-radius: 50%;
opacity: 0.12;
}

.why::after {
content: ‘’;
position: absolute;
bottom: -80px; left: 100px;
width: 300px; height: 300px;
background: var(–yellow);
border-radius: 50%;
opacity: 0.08;
}

.why .section-label { color: var(–blush); }

.why .section-title {
color: white;
margin-bottom: 48px;
}

.why-grid {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 16px;
position: relative;
z-index: 1;
}

.why-card {
background: rgba(255,255,255,0.05);
border: 1px solid rgba(255,255,255,0.08);
border-radius: 20px;
padding: 28px 24px;
transition: background 0.2s;
}

.why-card:hover { background: rgba(255,255,255,0.08); }

.why-card-icon {
font-size: 26px;
margin-bottom: 14px;
}

.why-card-title {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
font-weight: 700;
color: white;
margin-bottom: 8px;
letter-spacing: -0.3px;
}

.why-card-desc {
font-size: 14px;
color: rgba(255,255,255,0.45);
line-height: 1.65;
font-weight: 300;
}

/* WAITLIST */
.waitlist {
padding: 120px 48px;
text-align: center;
max-width: 640px;
margin: 0 auto;
}

.waitlist .section-title {
margin: 0 auto 16px;
text-align: center;
}

.waitlist-sub {
font-size: 16px;
color: var(–mid);
margin-bottom: 40px;
font-weight: 300;
line-height: 1.6;
}

.waitlist-form {
display: flex;
gap: 10px;
max-width: 420px;
margin: 0 auto 16px;
}

.waitlist-input {
flex: 1;
padding: 15px 20px;
border: 1.5px solid rgba(42,31,26,0.15);
border-radius: 100px;
font-size: 15px;
font-family: ‘DM Sans’, sans-serif;
background: white;
color: var(–dark);
outline: none;
transition: border-color 0.2s;
}

.waitlist-input:focus {
border-color: var(–warm-red);
}

.waitlist-input::placeholder { color: rgba(42,31,26,0.3); }

.waitlist-note {
font-size: 12px;
color: rgba(42,31,26,0.35);
}

.waitlist-count {
display: inline-flex;
align-items: center;
gap: 8px;
background: var(–yellow);
padding: 8px 16px;
border-radius: 100px;
font-size: 13px;
font-weight: 500;
color: var(–dark);
margin-bottom: 32px;
}

/* FOOTER */
footer {
border-top: 1.5px solid rgba(42,31,26,0.08);
padding: 32px 48px;
display: flex;
justify-content: space-between;
align-items: center;
}

.footer-logo {
font-family: ‘Playfair Display’, serif;
font-size: 18px;
font-weight: 700;
color: var(–dark);
}

.footer-note {
font-size: 13px;
color: rgba(42,31,26,0.35);
}

/* ANIMATIONS */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(24px); }
to { opacity: 1; transform: translateY(0); }
}

@keyframes floatY {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-8px); }
}

.phone-wrap { animation: floatY 4s ease-in-out infinite; }

/* SUCCESS STATE */
.success-msg {
display: none;
color: var(–warm-red);
font-size: 14px;
font-weight: 500;
margin-top: 12px;
animation: fadeUp 0.3s ease;
}

/* RESPONSIVE */
@media (max-width: 768px) {
nav { padding: 20px 24px; }
.nav-links { display: none; }
.hero { grid-template-columns: 1fr; padding: 100px 24px 60px; text-align: center; }
.hero::before { display: none; }
.hero-sub { max-width: 100%; margin-left: auto; margin-right: auto; }
.hero-actions { justify-content: center; }
.hero-right { order: -1; }
.float-badge-1, .float-badge-2 { display: none; }
.section { padding: 70px 24px; }
.steps { grid-template-columns: 1fr; }
.why { margin: 0 12px; padding: 70px 24px; }
.why-grid { grid-template-columns: 1fr; }
.waitlist { padding: 80px 24px; }
.waitlist-form { flex-direction: column; }
footer { flex-direction: column; gap: 12px; text-align: center; padding: 24px; }
}

  </style>
</head>
